# Firebase (Authentication + Firestore)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-side only)
FIREBASE_SERVICE_ACCOUNT_KEY=

# Cloudinary (document uploads — client-side unsigned upload)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Cloudinary Admin API (server-side only — for deleting files)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP — branded password-reset / verification emails (server-side only).
# If unset/invalid, the app automatically falls back to Firebase's built-in email.
#
# Pick the host that matches the domain's actual mail provider (check the MX
# records if unsure):
#   GoDaddy Workspace/secureserver (MX *.secureserver.net) -> smtpout.secureserver.net
#   Titan / GoDaddy Professional    (MX *.titan.email)      -> smtp.titan.email
#   Microsoft 365                   (MX *.outlook.com)       -> smtp.office365.com (port 587, secure=false)
#
# sikshawallahfbg.in resolves to GoDaddy secureserver, so use the values below.
# IMPORTANT: SMTP_PASS is the MAILBOX password, NOT your GoDaddy/cPanel account
# password. Paste values WITHOUT surrounding quotes or trailing spaces.
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=admission@sikshawallahfbg.in
SMTP_PASS=
# From address — must match SMTP_USER (providers reject a mismatched From).
EMAIL_FROM=admission@sikshawallahfbg.in

# Public site URL (used to build links inside emails)
NEXT_PUBLIC_SITE_URL=https://sikshawallahfbg.in

# Kill switch — set to "true" to replace the public homepage with a
# maintenance screen. Any other value (or unset) keeps the site live.
# NEXT_PUBLIC_* vars are inlined at build time, so changing this needs a
# redeploy/restart to take effect.
NEXT_PUBLIC_SITE_KILL_SWITCH=false
