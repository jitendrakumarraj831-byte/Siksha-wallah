# ─── Firebase (Client SDK) ─────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
#
# Firebase Console setup required:
#   Authentication → Sign-in method → Enable "Phone" (for OTP login)
#   Authentication → Sign-in method → Enable "Email/Password"
#   Storage → Rules → Allow authenticated reads/writes (see below)
#   Storage → Rules example:
#     rules_version = '2';
#     service firebase.storage {
#       match /b/{bucket}/o {
#         match /documents/{userId}/{allPaths=**} {
#           allow read, write: if request.auth != null && request.auth.uid == userId;
#         }
#       }
#     }

# ─── Razorpay Payment Gateway ───────────────────────────────────────────────────
# Get from Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Email (Nodemailer via Gmail) ───────────────────────────────────────────────
# Use a Gmail app password (not your main password)
# Generate at: myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=
CONTACT_EMAIL=inquiries@sikshawallah.com

# ─── Google Analytics 4 ────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Admin Panel Credentials (SERVER-SIDE ONLY — never NEXT_PUBLIC) ───────────────
# Validated in /api/admin/login. These are NOT shipped to the browser.
# IMPORTANT: change these before production. Defaults (admin / Siksha@2025!) apply
# only if these are unset.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# Secret used to HMAC-sign the admin session cookie. Use a long random string
# (e.g. `openssl rand -hex 32`). REQUIRED in production.
ADMIN_SESSION_SECRET=

# ─── Firebase Admin (server-side, optional) ───────────────────────────────────────
# On Firebase App Hosting / GCP, Application Default Credentials are used
# automatically — leave this blank. Only set it for non-GCP hosting: paste the
# full service-account JSON (single line) to enable server-side admin reads.
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sikshawallah.com
