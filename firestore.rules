rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Siksha Wallah — Firestore Security Rules
//
// Architecture: The office dashboard logs in with a signed server cookie, NOT a
// Firebase Auth user. Its data reads therefore reach Firestore as *anonymous*
// client-SDK requests, so the collections it lists (users, inquiries,
// course_applications) allow public read. Writes/updates stay restricted, and
// status/note changes still go through the cookie-gated Admin SDK API
// (/api/admin/*). The more locked-down "reads only via Admin SDK" setup needs a
// working firebase-admin backend; see /api/admin/debug.
//
// Collections in use: users, inquiries, course_applications, documents,
//                     activities, courses
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Public lead-capture — guests submit inquiries.
    // Office lists all inquiries via the client SDK (anonymous office cookie),
    // so read is public. Status/note updates go through the Admin SDK API.
    match /inquiries/{id} {
      allow create: if true;
      allow read:   if true;
      allow update, delete: if false;
    }

    // Course applications.
    // Office lists all applications via the client SDK (anonymous office cookie),
    // so read is public — a student reading their own is a subset of this.
    // Status/note updates go through the Admin SDK API.
    match /course_applications/{id} {
      allow create: if true;
      allow read:   if true;
      allow update, delete: if false;
    }

    // Activity log — public create (guest event tracking).
    // Office reads via real-time subscribeActivities (client SDK onSnapshot).
    match /activities/{id} {
      allow create: if true;
      allow read:   if true;
      allow update, delete: if false;
    }

    // Student profiles.
    // Office lists all students via the client SDK (anonymous office cookie), so
    // read is public. Create/update stay owner-only; no client deletes.
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read:   if true;
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Documents — owner create/read/delete only.
    match /documents/{id} {
      allow create: if isOwner(request.resource.data.uid);
      allow read, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Course catalog — public read, no client writes.
    match /courses/{id} {
      allow read:  if true;
      allow write: if false;
    }

    // Student ⇄ counsellor chat. A student reads/creates only their own thread.
    // The office replies via the Admin SDK (/api/admin/chat), which bypasses
    // these rules.
    match /messages/{id} {
      allow create: if isOwner(request.resource.data.studentId)
                    && request.resource.data.sender == 'student';
      allow read:   if isOwner(resource.data.studentId);
      // Student may only flip their own "readByStudent" flag — nothing else.
      allow update: if isOwner(resource.data.studentId)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readByStudent']);
      allow delete: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
