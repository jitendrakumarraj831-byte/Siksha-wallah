rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Siksha Wallah — Firestore Security Rules
//
// Architecture: Office dashboard reads/writes private collections through the
// cookie-gated server API (/api/admin/*) using Firebase Admin SDK which
// bypasses these rules. Client SDK is used only for student-owned data.
//
// Collections in use: users, inquiries, course_applications, documents,
//                     activities, courses
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Public lead-capture — guests submit inquiries.
    // All reads/updates via Admin SDK server API only.
    match /inquiries/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Students can read their own application after login.
    // All status/note updates via Admin SDK server API only.
    match /course_applications/{id} {
      allow create: if true;
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Activity log — public create (guest event tracking).
    // Office reads via real-time subscribeActivities (client SDK onSnapshot).
    match /activities/{id} {
      allow create: if true;
      allow read:   if true;
      allow update, delete: if false;
    }

    // Student profiles — owner read/update only.
    // Office reads all via Admin SDK (/api/admin/data?type=students).
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read:   if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Documents — owner create/read/delete only.
    match /documents/{id} {
      allow create: if isOwner(request.resource.data.uid);
      allow read, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Course catalog — public read, no client writes.
    match /courses/{id} {
      allow read:  if true;
      allow write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
