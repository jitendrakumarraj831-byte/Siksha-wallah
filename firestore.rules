rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Siksha Wallah — Firestore Security Rules (hardened)
//
// Architecture:
//   • Students authenticate with Firebase Auth and may touch ONLY their own data.
//   • The office dashboard logs in with a signed httpOnly cookie (NOT a Firebase
//     Auth user). It therefore reads private collections through the cookie-gated
//     Admin SDK API (/api/admin/*), which BYPASSES these rules. So these rules do
//     NOT grant the office any client read — they don't need to.
//
// Result: no collection holding personal data is world-readable. Guests can still
// submit lead-capture forms (create-only), and each student can read only their
// own profile, applications and documents.
//
// ⚠️ DEPLOY PREREQUISITE: the office reads require a working firebase-admin
// backend. Confirm /api/admin/debug returns { ok: true } BEFORE deploying these
// rules, otherwise the office dashboard will show no data. See SECURITY.md.
//
// Collections: users, inquiries, course_applications, documents, activities,
//              courses, messages
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Public lead-capture — guests submit inquiries (create-only). Reading the
    // full list is office-only and goes through the Admin SDK API; no client
    // read, no client update/delete.
    match /inquiries/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Course applications. Guests/students submit (create-only). A signed-in
    // student may read ONLY their own applications (rule below matches the
    // dashboard/documents queries `where('userId','==', uid)`). The full list +
    // status/note writes are office-only via the Admin SDK API.
    match /course_applications/{id} {
      allow create: if true;
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Activity log — public create (guest/visitor event tracking). Holds contact
    // details, so it is NOT client-readable; the office feed loads via the Admin
    // SDK API (/api/admin/data?type=activities).
    match /activities/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Student profiles — each student reads/writes ONLY their own. The office
    // lists all students via the Admin SDK API. No client deletes.
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read:   if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Documents — owner create/read/delete only (office reads via Admin SDK API).
    match /documents/{id} {
      allow create: if isOwner(request.resource.data.uid);
      allow read, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Course catalog — public read, no client writes.
    match /courses/{id} {
      allow read:  if true;
      allow write: if false;
    }

    // Student ⇄ counsellor chat. A student reads/creates only their own thread.
    // The office replies via the Admin SDK (/api/admin/chat), which bypasses
    // these rules.
    match /messages/{id} {
      allow create: if isOwner(request.resource.data.studentId)
                    && request.resource.data.sender == 'student';
      allow read:   if isOwner(resource.data.studentId);
      // Student may only flip their own "readByStudent" flag — nothing else.
      allow update: if isOwner(resource.data.studentId)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readByStudent']);
      allow delete: if false;
    }

    // Notifications — written by Admin SDK (office actions); students read/update only their own.
    match /notifications/{id} {
      allow read:   if isSignedIn() && resource.data.uid == request.auth.uid;
      // Students can only mark their own notifications as read
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    // Contact form messages — public create only; reads are office-only via Admin SDK.
    match /contacts/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
