rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Siksha Wallah — Firebase Storage Security Rules
//
// Architecture:
//   • Students upload files only to their own UID-scoped path.
//   • File size is capped at 5 MB server-side (mirrors client validation).
//   • Only PDF, JPEG and PNG are accepted (matches the upload UI allowlist).
//   • Admin downloads use the stored download URL (token-based, not rule-gated)
//     after fetching metadata from Firestore via the Admin SDK API.
//   • Everything outside /documents/{uid}/ is denied by default.
// ─────────────────────────────────────────────────────────────────────────────

service firebase.storage {
  match /b/{bucket}/o {

    // Student document uploads — owner-scoped read + write.
    // Write constraints enforce the same limits as the client UI.
    match /documents/{uid}/{fileName} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png)|application/pdf');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Default deny — no other path is accessible.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
